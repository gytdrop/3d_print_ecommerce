# ─────────────────────────────────────────────────────────────
# Secrets & local config — NEVER commit
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ─────────────────────────────────────────────────────────────
# Dependencies — regenerable from package-lock.json / yarn.lock
# ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─────────────────────────────────────────────────────────────
# Build output — regenerable
# ─────────────────────────────────────────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# ─────────────────────────────────────────────────────────────
# OS junk
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────
# Editors & AI tools
# ─────────────────────────────────────────────────────────────
.aider*
.aider.chat.history.md
.aider.input.history
.aider.tags.cache.v4
.vscode/
.idea/
*.swp
*.swo
*~

# ─────────────────────────────────────────────────────────────
# Test / scratch artifacts (root-level — not part of the app)
# ─────────────────────────────────────────────────────────────
/apple.stl
/test.stl
/gen_apple.py

# ─────────────────────────────────────────────────────────────
# Coverage / cache
# ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
.cache/
.parcel-cache/
.turbo/

# ─────────────────────────────────────────────────────────────
# Vercel
# ─────────────────────────────────────────────────────────────
.vercel
